aws_region    = "us-east-1"
instance_type = "t3.medium"
key_name      = "openclaw-key"

# Environment variables passed to the OpenClaw container.
# Uncomment the LLM provider(s) and channel tokens you want to use.
openclaw_env_vars = {
  # ANTHROPIC_API_KEY  = "sk-ant-..."
  # OPENAI_API_KEY     = "sk-..."
  # GOOGLE_API_KEY     = "..."
  # TELEGRAM_BOT_TOKEN = "123:abc..."
}

# Telegram user IDs allowed to message the bot.
# Uncomment and add your ID to enable Telegram access.
# To find your ID, message the bot — it will reply with your user ID.
# telegram_allowed_users = ["7088233388"]

# Restrict SSH and gateway access to your IP (recommended).
# Uncomment and replace with your IP.
# allowed_ssh_cidrs     = ["203.0.113.10/32"]
# allowed_gateway_cidrs = ["203.0.113.10/32"]
