aws_region    = "us-east-1"
instance_type = "t3.medium"
key_name      = "openclaw-key"

# Pass the API key(s) for whichever LLM provider you use.
# OpenClaw supports Anthropic, OpenAI, Google, and others.
llm_env_vars = {
  ANTHROPIC_API_KEY = "sk-ant-..."
  # OPENAI_API_KEY  = "sk-..."
  # GOOGLE_API_KEY  = "..."
}

# Restrict access to your IP (recommended)
# allowed_ssh_cidrs     = ["203.0.113.10/32"]
# allowed_gateway_cidrs = ["203.0.113.10/32"]
